# Phase 2 Worker-only values. For local development, copy this file to worker/.dev.vars.
# For deployed Workers, set NOCODB_API_TOKEN with:
# wrangler secret put NOCODB_API_TOKEN --config worker/wrangler.toml
NOCODB_BASE_URL=https://nocodb.horizon.kukiinpi.us
NOCODB_API_TOKEN=replace-with-nocodb-token
NOCODB_TABLE_ID=mf28g2tn6zzdo3e
NOCODB_SOURCE_FIELD=Source
NOCODB_SOURCE_VALUE=gemini
NOCODB_FIRST_REVIEW_FIELD="1st Review"
NOCODB_SECOND_REVIEW_FIELD="2nd Review"
NOCODB_THIRD_REVIEW_FIELD="3rd Review"
NOCODB_PAGE_SIZE=1000
